# Kopiere diese Datei als .env und fülle die Werte aus
# cp .env.example .env

# Gemini API-Schlüssel (kostenlos unter https://aistudio.google.com)
GEMINI_API_KEY=dein_api_schluessel_hier

# JWT-Geheimschlüssel (beliebige lange zufällige Zeichenkette)
JWT_SECRET=aendere_diesen_wert_in_produktion

# Optionaler Port (Standard: 80)
# PORT=80

# Optionale Frontend-URL (für CORS im Backend)
# FRONTEND_URL=https://deine-domain.de
